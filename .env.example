# Airflow (obligatoire)
AIRFLOW_UID=50000

# Airflow Web UI credentials
_AIRFLOW_WWW_USER_USERNAME=airflowGoodAir
_AIRFLOW_WWW_USER_PASSWORD=airflowGoodAir2026!
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__DEFAULT_TIMEZONE='Europe/Paris'
AIRFLOW__WEBSERVER__DEFAULT_UI_TIMEZONE='Europe/Paris'

# Clés API (à remplacer par vos vraies clés)
OWM_API_KEY=your_openweathermap_api_key_here
AQICN_API_KEY=your_aqicn_token_here

# SQL Server
MSSQL_SA_PASSWORD=yourStrong(!)Password
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=GoodAirDW

# MinIO (Data Lake)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver